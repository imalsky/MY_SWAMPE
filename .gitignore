# Retrieval: data/ and plots/ hold regenerable artifacts. Keep the dirs
# (via .gitkeep) but ignore their contents.
retrieval/data/**
retrieval/plots/**
!retrieval/data/
!retrieval/plots/
!retrieval/data/.gitkeep
!retrieval/plots/.gitkeep
# legacy run-output folders (pre-reorg), if any reappear:
retrieval/*_outputs/**

