#!/bin/bash
#PBS -N MY_SWAMPE_W43B
#PBS -q gpu_long
#PBS -W group_list=s2458
#PBS -l select=1:ncpus=72:ngpus=1:mem=400gb:model=gh200
#PBS -l walltime=36:00:00
#PBS -j oe
#
# Run the WASP-43 b real-data pilot retrieval on NASA NAS GH200.
set -euo pipefail

if [ -n "${PROJECT_ROOT:-}" ]; then :
elif [ -n "${PBS_O_WORKDIR:-}" ] && [ -d "${PBS_O_WORKDIR}/retrieval/wasp_43b_test" ]; then
  PROJECT_ROOT="${PBS_O_WORKDIR}"
elif [ -n "${PBS_O_WORKDIR:-}" ] \
     && [ "$(basename "${PBS_O_WORKDIR}")" = "wasp_43b_test" ]; then
  PROJECT_ROOT="$(cd -- "${PBS_O_WORKDIR}/../.." && pwd -P)"
else
  _sd="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
  PROJECT_ROOT="$(cd -- "${_sd}/../.." && pwd -P)"
fi

SUITE_DIR="${PROJECT_ROOT}/retrieval/wasp_43b_test"
RETRIEVAL_DIR="${PROJECT_ROOT}/retrieval/scripts"
if [ ! -d "${SUITE_DIR}" ] || [ ! -d "${RETRIEVAL_DIR}" ]; then
  echo "ERROR: could not locate retrieval/wasp_43b_test and retrieval/scripts under PROJECT_ROOT=${PROJECT_ROOT}"
  exit 1
fi

LOG_DIR="${SUITE_DIR}/logs"
mkdir -p "${LOG_DIR}"
_jobid="${PBS_JOBID:-manual_$$}"
LOG_FILE="${LOG_DIR}/WASP43B_${_jobid%%.*}.log"
exec > >(tee -a "${LOG_FILE}") 2>&1
echo "Live log: tail -f ${LOG_FILE}"
echo "PROJECT_ROOT=${PROJECT_ROOT}"

export http_proxy="${HTTPS_PROXY:-${http_proxy:-http://proxy.nas.nasa.gov:3128}}"
export https_proxy="${http_proxy}" HTTP_PROXY="${http_proxy}" HTTPS_PROXY="${http_proxy}"

module purge 2>/dev/null || true
module use -a /swbuild/analytix/tools/modulefiles 2>/dev/null || true
module load miniconda3/gh2 2>/dev/null || true
CONDA_BASE="$(conda info --base)"
# shellcheck disable=SC1091
source "${CONDA_BASE}/etc/profile.d/conda.sh"
CONDA_ENV="${CONDA_ENV:-pyt2_8_gh}"
conda activate "${CONDA_ENV}"

: "${MY_SWAMPE_RETRIEVAL_SCRATCH:=/nobackup/${USER}/.swampe_retrieval}"
export PYTHONUSERBASE="${MY_SWAMPE_RETRIEVAL_SCRATCH}/userbase"
export PIP_CACHE_DIR="${MY_SWAMPE_RETRIEVAL_SCRATCH}/cache/pip"
unset PYTHONNOUSERSITE
mkdir -p "${PYTHONUSERBASE}" "${PIP_CACHE_DIR}"

python - <<'PY' || python -m pip install --user -U h5py
import h5py  # noqa: F401
PY

# Python's SSL trust store in the shared conda env is stale (same failure mode
# run_nas.pbs works around for pip): probe system CA bundles so the Zenodo
# fetch below can verify certificates. Non-fatal -- fetch_wasp43b_data.py
# tolerates being offline when the archive already exists on disk.
if ! python -c "
import ssl, urllib.request
urllib.request.urlopen('https://zenodo.org/api/records/10525170', context=ssl.create_default_context(), timeout=15)
" >/dev/null 2>&1; then
  for _cand in /etc/pki/tls/certs/ca-bundle.crt /etc/ssl/certs/ca-certificates.crt \
               /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem /etc/ssl/cert.pem; do
    if [ -f "${_cand}" ] && python -c "
import ssl, urllib.request, sys
urllib.request.urlopen('https://zenodo.org/api/records/10525170', context=ssl.create_default_context(cafile=sys.argv[1]), timeout=15)
" "${_cand}" >/dev/null 2>&1; then
      echo "[net] using system CA bundle for the Zenodo fetch: ${_cand}"
      export SSL_CERT_FILE="${_cand}" REQUESTS_CA_BUNDLE="${_cand}"
      break
    fi
  done
fi

cd -P "${SUITE_DIR}"
python -u scripts/fetch_wasp43b_data.py
python -u scripts/prepare_wasp43b_observations.py

export PROJECT_ROOT
export MY_SWAMPE_RETRIEVAL_PRESET="${MY_SWAMPE_RETRIEVAL_PRESET:-gpu}"
export MY_SWAMPE_RETRIEVAL_USE_X64="${MY_SWAMPE_RETRIEVAL_USE_X64:-1}"
# Production config (30 h-budget run: semi-implicit dt=600, N=256, per-stage MALA
# adaptation, eclipse-edge masking). Point at config/wasp43b_pilot_gpu.json to
# reproduce the 2026-07 pilot instead.
export MY_SWAMPE_RETRIEVAL_OVERRIDES_FILE="${MY_SWAMPE_RETRIEVAL_OVERRIDES_FILE:-${SUITE_DIR}/config/wasp43b_production_gpu.json}"
export MY_SWAMPE_PLOT_OUT_DIR="${SUITE_DIR}/outputs"
export MY_SWAMPE_PLOTS_DIR="${SUITE_DIR}/plots"

bash "${RETRIEVAL_DIR}/run_nas.pbs"
